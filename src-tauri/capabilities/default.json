{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": ["core:default", "opener:default"],
  "commands": {
    "allow": [
      "get_cards",
      "add_card",
      "delete_card",
      "move_card",
      "update_card"
    ]
  }
}
